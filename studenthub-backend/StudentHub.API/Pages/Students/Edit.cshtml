@page
@model StudentHub.API.Pages.Students.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>User</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="User.Id" />
            <div class="form-group">
                
                <label asp-for="User.Email" class="control-label"></label>
                <input asp-for="User.Email" class="form-control" />
                <span asp-validation-for="User.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="User.FullName" class="control-label"></label>
                <input asp-for="User.FullName" class="form-control" />
                <span asp-validation-for="User.FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="User.Faculty" class="control-label"></label>
                <input asp-for="User.Faculty" class="form-control" />
                <span asp-validation-for="User.Faculty" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="User.Year" class="control-label"></label>
                <input asp-for="User.Year" class="form-control" />
                <span asp-validation-for="User.Year" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="User.Section" class="control-label"></label>
                <input asp-for="User.Section" class="form-control" />
                <span asp-validation-for="User.Section" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="User.StudyType" class="control-label"></label>
                <input asp-for="User.StudyType" class="form-control" />
                <span asp-validation-for="User.StudyType" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="User.EntraObjectId" class="control-label"></label>
                <input asp-for="User.EntraObjectId" class="form-control" />
                <span asp-validation-for="User.EntraObjectId" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="User.IsAdmin" /> @Html.DisplayNameFor(model => model.User.IsAdmin)
                </label>
            </div>
            <div class="form-group">
                
                <label asp-for="User.CreatedAt" class="control-label"></label>
                <input asp-for="User.CreatedAt" class="form-control" />
                <span asp-validation-for="User.CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="User.IsActive" /> @Html.DisplayNameFor(model => model.User.IsActive)
                </label>
            </div>
            <div class="form-group">
                
                <label asp-for="User.ProfilePhotoUrl" class="control-label"></label>
                <input asp-for="User.ProfilePhotoUrl" class="form-control" />
                <span asp-validation-for="User.ProfilePhotoUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

