@page
@model StudentHub.API.Pages.Moderation.IndexModel
@{
    ViewData["Title"] = "Moderare Conținut";
}

<div class="admin-page">
    <div class="admin-header">
        <h1 class="admin-title">🚨 Moderare Conținut</h1>
    </div>
    <p><a href="/Admin/Index">← Înapoi la Dashboard</a></p>

    <div class="stats-bar">
        <span class="stats-text">
            @if (Model.TotalFlagged == 0)
            {
                <span style="color:#10b981;">✅ Niciun mesaj semnalat momentan.</span>
            }
            else
            {
                <span style="color:#dc2626;">⚠️ @Model.TotalFlagged mesaje semnalate</span>
            }
        </span>
    </div>

    @if (Model.FlaggedMessages.Count == 0)
    {
        <div class="empty-state">
            <span class="empty-icon">✅</span>
            <p>Totul e în regulă!</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Mesaj</th>
                        <th>Utilizator</th>
                        <th>Camera</th>
                        <th>Raportări</th>
                        <th>Data</th>
                        <th>Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model.FlaggedMessages)
                    {
                        <tr>
                            <td>
                                <span class="msg-text">@msg.Text</span>
                                @if (msg.IsEdited)
                                {
                                    <span class="badge-edited">editat</span>
                                }
                            </td>
                            <td><span class="user-name">@msg.UserName</span></td>
                            <td><span class="room-badge">@msg.RoomLabel</span></td>
                            <td>
                                @if (msg.ReportCount > 0)
                                {
                                    <span class="report-badge">🚩 @msg.ReportCount</span>
                                }
                                else
                                {
                                    <span style="color:#9ca3af; font-size:0.8rem;">—</span>
                                }
                            </td>
                            <td><span class="date-text">@msg.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span></td>
                            <td>
                                <div class="action-btns">
                                    <form method="post" asp-page-handler="Ignore" style="display:inline">
                                        <input type="hidden" name="id" value="@msg.Id" />
                                        <button type="submit" class="btn-ignore"
                                                onclick="return confirm('Marchezi ca OK?')">✓ Ignoră</button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" style="display:inline">
                                        <input type="hidden" name="id" value="@msg.Id" />
                                        <button type="submit" class="btn-danger"
                                                onclick="return confirm('Ștergi mesajul definitiv?')">🗑️ Șterge</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@Html.AntiForgeryToken()

<style>
.admin-page { padding: 2rem; max-width: 1100px; font-family: 'Segoe UI', system-ui, sans-serif; }
.admin-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
.admin-title { font-size: 1.5rem; font-weight: 800; color: #0f1f3d; margin: 0; }
.btn-back { background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 0.5rem 1rem; text-decoration: none; color: #374151; font-size: 0.875rem; }

.stats-bar { margin-bottom: 1.5rem; font-size: 0.9rem; font-weight: 600; }

.empty-state { text-align: center; padding: 4rem; color: #6b7280; }
.empty-icon { font-size: 3rem; display: block; margin-bottom: 1rem; }

.table-wrapper { border: 1.5px solid #e5e7eb; border-radius: 0.875rem; overflow: hidden; background: white; box-shadow: 0 2px 8px rgba(15,31,61,0.05); }

.data-table { width: 100%; border-collapse: collapse; }
.data-table thead tr { background: #f9fafb; border-bottom: 2px solid #e5e7eb; }
.data-table th { padding: 0.875rem 1rem; text-align: left; font-size: 0.75rem; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; }
.data-table td { padding: 1rem; border-bottom: 1px solid #f3f4f6; vertical-align: middle; }
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: #fafafa; }

.msg-text { font-size: 0.875rem; color: #374151; font-weight: 500; background: #fef2f2; padding: 0.25rem 0.5rem; border-radius: 0.375rem; border-left: 3px solid #dc2626; display: inline-block; }
.badge-edited { font-size: 0.7rem; color: #6b7280; font-style: italic; margin-left: 0.5rem; }
.user-name { font-size: 0.875rem; font-weight: 600; color: #0f1f3d; }
.room-badge { font-size: 0.8rem; background: #f3f4f6; padding: 0.25rem 0.625rem; border-radius: 2rem; color: #374151; font-weight: 500; }
.date-text { font-size: 0.8rem; color: #6b7280; }

.action-btns { display: flex; gap: 0.5rem; }
.btn-ignore { padding: 0.375rem 0.75rem; background: #f0fdf4; border: 1.5px solid #86efac; border-radius: 0.5rem; color: #16a34a; font-size: 0.8rem; font-weight: 600; cursor: pointer; font-family: 'Segoe UI', system-ui, sans-serif; transition: all 0.15s; }
.btn-ignore:hover { background: #dcfce7; }
.btn-danger { padding: 0.375rem 0.75rem; background: #fef2f2; border: 1.5px solid #fca5a5; border-radius: 0.5rem; color: #dc2626; font-size: 0.8rem; font-weight: 600; cursor: pointer; font-family: 'Segoe UI', system-ui, sans-serif; transition: all 0.15s; }
.btn-danger:hover { background: #fee2e2;}
    .report-badge {
        font-size: 0.8rem;
        background: #fffbeb;
        border: 1.5px solid #fcd34d;
        padding: 0.25rem 0.625rem;
        border-radius: 2rem;
        color: #92400e;
        font-weight: 700;
    }
</style>